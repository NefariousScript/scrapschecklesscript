------------------------------------------------------------------------
-- Core: Add Sheckles logic
------------------------------------------------------------------------

local function setStatus(msg, color)
	StatusLabel.Text = msg
	StatusLabel.TextColor3 = color or Color3.fromRGB(120, 110, 90)
end

local function shakeFrame()
	local orig = Frame.Position
	for i = 1, 6 do
		task.wait(0.04)
		Frame.Position = orig + UDim2.new(0, math.random(-5,5), 0, 0)
	end
	Frame.Position = orig
end

local function addSheckles()
	local input = TextBox.Text:match("^%s*(.-)%s*$")
	local amount = tonumber(input)

	if not amount or amount <= 0 or amount ~= math.floor(amount) then
		setStatus("⚠ Enter a valid whole number!", Color3.fromRGB(220, 80, 80))
		task.spawn(shakeFrame)
		return
	end

	if amount > 1e9 then
		setStatus("⚠ Max is 1,000,000,000!", Color3.fromRGB(220, 80, 80))
		return
	end

	Sheckles.Value = Sheckles.Value + amount
	burstVFX(math.min(math.ceil(amount / 500), 8))

	TweenService:Create(AddBtn, TweenInfo.new(0.1), {
		BackgroundColor3 = Color3.fromRGB(80, 210, 100)
	}):Play()
	task.delay(0.25, function()
		TweenService:Create(AddBtn, TweenInfo.new(0.2), {
			BackgroundColor3 = Color3.fromRGB(46, 160, 60)
		}):Play()
	end)

	local display = amount >= 1000 and (math.floor(amount/100)/10).."K" or tostring(amount)
	setStatus("✅ Added ¢" .. display .. " Sheckles!", Color3.fromRGB(100, 220, 100))
	TextBox.Text = ""

	task.delay(3, function()
		setStatus("Enter an amount and press Add")
	end)
end

AddBtn.MouseButton1Click:Connect(addSheckles)
TextBox.FocusLost:Connect(function(enterPressed)
	if enterPressed then addSheckles() end
end)

AddBtn.MouseEnter:Connect(function()
	TweenService:Create(AddBtn, TweenInfo.new(0.15), {
