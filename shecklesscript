    end
    
    minimizeBtn.Text = "+"
end

local function restore()
    minimized = false
    for _, v in pairs(Frame:GetChildren()) do
        if v:IsA("GuiObject") and v ~= TitleBar and v ~= minimizeBtn and v ~= CloseBtn then
