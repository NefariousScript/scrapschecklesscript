local function spawnPopVFX(position)
    task.spawn(function()
        local model = Instance.new("Model")
        model.Parent = Temp
        local vfx = PopVFX:Clone()
        vfx.Parent = model
        model:ScaleTo(0.5)
        vfx.Position = position
        task.wait()
        for _, v in pairs(vfx:GetDescendants()) do
            if v:IsA("ParticleEmitter") then
                v:Emit(v:GetAttribute("EmitCount") or 10)
            end
        end
        game.Debris:AddItem(model, 3)
    end)
end

local function spawnPoofVFX(position)
    task.spawn(function()
        local vfx = Poof:Clone()
        vfx.Parent = Temp
        vfx.Position = position
        task.wait()
        for _, v in pairs(vfx:GetDescendants()) do
            if v:IsA("ParticleEmitter") then
                v:Emit(math.random(7, 11))
            end
        end
        game.Debris:AddItem(vfx, 3)
    end)
end

local function burstVFX(count)
    local base = hrp.Position
    for i = 1, count do
        local offset = Vector3.new(
            math.random(-4, 4),
            math.random(0, 3),
            math.random(-4, 4)
        )
        task.delay(i * 0.08, function()
            spawnPopVFX(base + offset)
        end)
    end
    spawnPoofVFX(base + Vector3.new(0, 1, 0))
end

