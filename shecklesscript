        if v:IsA("GuiObject") then
            TweenService:Create(v, TweenInfo.new(0.18), {BackgroundTransparency = v.BackgroundTransparency, TextTransparency = 0}):Play()
        end
    end
    
    -- Restore icon to 3 bars
    for _, bar in ipairs(iconContainer:GetChildren()) do
        if bar:IsA("Frame") then
            bar.Rotation = 0
            bar.Visible = true
        end
    end
