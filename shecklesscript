-- ADD SHECKLES LOGIC
----------------------------------------------------
local function setStatus(msg, color)
    statusLabel.Text = msg
    statusLabel.TextColor3 = color or Color3.fromRGB(120, 80, 160)
end

local function shakeFrame()
    local orig = main.Position
    for i = 1, 6 do
        task.wait(0.04)
        main.Position = orig + UDim2.new(0, math.random(-5, 5), 0, 0)
    end
    main.Position = orig
end

local function addSheckles()
    local input = textBox.Text:match("^%s*(.-)%s*$")
    local amount = tonumber(input)

    if not amount or amount <= 0 or amount ~= math.floor(amount) then
        setStatus("âš  Enter a valid whole number!", Color3.fromRGB(220, 60, 255))
        task.spawn(shakeFrame)
        return
    end

    if amount > 1e9 then
        setStatus("âš  Max is 1,000,000,000!", Color3.fromRGB(220, 60, 255))
        return
    end

    Sheckles.Value = Sheckles.Value + amount
    burstVFX(math.min(math.ceil(amount / 500), 8))

    TweenService:Create(addBtn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(160, 60, 255)}):Play()
    task.delay(0.25, function()
        TweenService:Create(addBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(90, 0, 150)}):Play()
    end)

    local display = amount >= 1000 and (math.floor(amount/100)/10).."K" or tostring(amount)
    setStatus("âœ… Added Â¢" .. display .. " Sheckles!", Color3.fromRGB(180, 80, 255))
    textBox.Text = ""

    task.delay(3, function()
        setStatus("Enter an amount and press Add")
    end)
end

addBtn.MouseButton1Click:Connect(addSheckles)
textBox.FocusLost:Connect(function(enterPressed)
    if enterPressed then addSheckles() end
end)

